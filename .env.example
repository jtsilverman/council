# Council uses Claude CLI (claude --print) by default — no API key needed.
# These keys are only required if you configure non-default providers in your council YAML.

# Anthropic Claude (for `provider: anthropic` in council YAML)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (for `provider: openai`)
OPENAI_API_KEY=sk-...

# Google Gemini (for `provider: gemini`)
GEMINI_API_KEY=...

# OpenRouter (single key gives access to most models, for `provider: openrouter`)
OPENROUTER_API_KEY=sk-or-...
